generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

// ================= USER =================

model User {
  id String @id @default(uuid()) @db.Uuid

  email String @unique

  username String

  // Admin login users only
  passwordHash String? @map("password_hash")

  // Google mobile users
  googleId String? @unique @map("google_id")

  authProvider AuthProvider @default(LOCAL) @map("auth_provider")

  avatarUrl String? @map("avatar_url")

  bio String?

  lastSeen DateTime?

  isPremium Boolean @default(false) @map("is_premium")

  premiumUntil DateTime? @map("premium_until")

  favoriteCount Int @default(0)

  dailyDownloadCount Int       @default(0) @map("daily_download_count")
  lastDownloadReset  DateTime? @map("last_download_reset")

  roleId String? @map("role_id") @db.Uuid

  role Role? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  sessions UserSession[]

  favorites Favorite[]

  downloads Download[]

  wallpaperLikes WallpaperLike[]

  subscriptions Subscription[]

  payments Payment[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([roleId])
  @@index([googleId])
  @@map("users")
}

enum AuthProvider {
  LOCAL

  GOOGLE
}

model Role {
  id String @id @default(uuid()) @db.Uuid

  name String @unique

  description String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  users User[]

  @@map("roles")
}

model UserSession {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  token String @unique

  ipAddress String? @map("ip_address")

  userAgent String? @map("user_agent")

  isActive Boolean @default(true) @map("is_active")

  loginAt DateTime @default(now()) @map("login_at") @db.Timestamptz(6)

  logoutAt DateTime? @map("logout_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([token])
  @@map("user_sessions")
}

// ================= CATEGORY =================

model Category {
  id String @id @default(uuid()) @db.Uuid

  name String @unique

  slug String @unique

  icon String?

  description String?

  folderName String @unique @map("folder_name")

  coverImage String? @map("cover_image")

  thumbnailUrl String? @map("thumbnail_url")

  wallpaperCount Int @default(0) @map("wallpaper_count")

  active Boolean @default(true)

  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  wallpapers Wallpaper[]

  @@index([active])
  @@index([sortOrder])
  @@map("categories")
}

// ================= WALLPAPER =================

model Wallpaper {
  id String @id @default(uuid()) @db.Uuid

  title String

  slug String @unique

  description String?

  categoryId String @db.Uuid

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Images

  originalPath String @map("original_path")

  displayPath String @map("display_path")

  thumbnailPath String @map("thumbnail_path")

  // Metadata

  originalName String @map("original_name")

  fileName String @map("file_name")

  mimeType String @map("mime_type")

  extension String

  // Dimensions

  width Int

  height Int

  aspectRatio Float @map("aspect_ratio")

  // File size

  originalSize Int @map("original_size")

  displaySize Int @map("display_size")

  thumbnailSize Int @map("thumbnail_size")

  // Image quality

  quality WallpaperQuality @default(UHD_4K)

  format String @default("webp")

  // Premium

  isPremium Boolean @default(false)

  isFeatured Boolean @default(false)

  featuredOrder Int @default(0) @map("featured_order")

  featuredAt DateTime? @map("featured_at")

  active Boolean @default(true)

  // Analytics

  likeCount Int @default(0)

  downloadCount Int @default(0)

  viewCount Int @default(0)

  // Search

  dominantColor String? @map("dominant_color")

  searchableText String? @map("searchable_text")

  checksum String? @unique

  blurHash String? @map("blur_hash")

  cacheVersion Int @default(1) @map("cache_version")

  status UploadStatus @default(PROCESSING)

  createdAt DateTime @default(now())

  deletedAt DateTime?

  updatedAt DateTime @updatedAt

  favorites Favorite[]

  downloadsHistory Download[]

  wallpaperLikes    WallpaperLike[]
  wallpaperVariants WallpaperVariant[]
  wallpaperTags     WallpaperTag[]

  @@index([categoryId])
  @@index([active])
  @@index([isFeatured])
  @@index([isPremium])
  @@index([downloadCount])
  @@index([likeCount])
  @@index([slug])
  @@index([active, categoryId])
  @@index([active, isPremium])
  @@index([active, isFeatured])
  @@index([categoryId, createdAt])
  @@index([downloadCount, likeCount])
  @@index([status])
  @@map("wallpapers")
}

enum WallpaperQuality {
  HD
  FULL_HD
  QHD
  UHD_4K
  UHD_8K
}

enum UploadStatus {
  PROCESSING
  READY
  FAILED
}

// ================= FAVORITES =================

model Favorite {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  wallpaperId String @map("wallpaper_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  wallpaper Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)

  @@unique([userId, wallpaperId])
  @@index([userId])
  @@index([wallpaperId])
  @@map("favorites")
}

model Tag {
  id String @id @default(uuid()) @db.Uuid

  name String @unique

  wallpapers WallpaperTag[]

  @@index([name])
  @@map("tags")
}

model WallpaperTag {
  wallpaperId String @db.Uuid

  tagId String @db.Uuid

  wallpaper Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([wallpaperId, tagId])
  @@index([tagId])
  @@index([wallpaperId])
  @@map("wallpaper_tags")
}

// ================= DOWNLOAD =================
model Download {
  id String @id @default(uuid()) @db.Uuid

  userId String? @map("user_id") @db.Uuid

  guestId String? @map("guest_id")

  wallpaperId String @map("wallpaper_id") @db.Uuid

  quality String @default("4K")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  guest Guest? @relation(fields: [guestId], references: [id], onDelete: Cascade)

  wallpaper Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([guestId])
  @@index([wallpaperId])
  @@index([createdAt])
  @@map("downloads")
}

// ================= LIKES =================

model WallpaperLike {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  wallpaperId String @map("wallpaper_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  wallpaper Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)

  @@unique([userId, wallpaperId])
  @@index([userId])
  @@index([wallpaperId])
  @@map("wallpaper_likes")
}

model WallpaperVariant {
  id String @id @default(uuid()) @db.Uuid

  wallpaperId String @db.Uuid

  type VariantType

  url String

  width Int

  height Int

  size Int

  format ImageFormat @default(WEBP)

  compressionQuality Int

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  wallpaper Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)

  isDefault Boolean @default(false)

  @@unique([wallpaperId, type])
  @@index([wallpaperId])
  @@index([type])
  @@map("wallpaper_variants")
}

enum ImageFormat {
  WEBP
  JPG
  PNG
  AVIF
}

enum VariantType {
  THUMBNAIL

  DISPLAY

  HD

  FULL_HD

  QHD

  UHD

  ORIGINAL
}

// ================= SUBSCRIPTION =================

model Subscription {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan SubscriptionPlan

  platform SubscriptionPlatform

  // Razorpay
  orderId   String? @unique
  paymentId String? @unique
  signature String?

  purchaseToken String? @unique

  transactionId String?

  amount Float?

  currency String?

  status PaymentStatus @default(PENDING)

  startDate DateTime

  endDate DateTime

  payments Payment[]

  active Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Payment {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid

  subscriptionId String? @db.Uuid

  orderId String @unique

  paymentId String? @unique

  signature String?

  platform SubscriptionPlatform

  amount Float

  currency String

  status PaymentStatus

  receipt String?

  notes Json?

  paidAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("payments")
}

enum SubscriptionPlatform {
  RAZORPAY

  GOOGLE

  APPLE

  STRIPE
}

enum SubscriptionPlan {
  FREE
  MONTHLY
  QUARTERLY
  YEARLY
  LIFETIME
}

enum PaymentStatus {
  PENDING

  PAID

  FAILED

  CANCELLED

  REFUNDED
}

model Guest {
  id String @id

  deviceHash String? @unique @map("device_hash")

  dailyDownloadCount Int @default(0) @map("daily_download_count")

  lastDownloadReset DateTime? @map("last_download_reset")

  downloads Download[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([deviceHash])
  @@map("guests")
}
